# Application Configuration
APP_NAME=user-api
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# Database Authentication Mode
# - password: For local development (default)
# - aad: For Azure with Managed Identity
DB_AUTH_MODE=password

# Database Connection (Password Mode - Local Development)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=user_user
DATABASE_PASSWORD=user_pass
DATABASE_NAME=user_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_POOL_PRE_PING=true

# Entra DB token lifecycle controls (used in AAD mode)
ENTRA_DB_TOKEN_LIFETIME_SECONDS=3600
ENTRA_DB_TOKEN_REFRESH_SKEW_SECONDS=300

# Database URL Overrides (optional)
# Use these to override the auto-constructed URLs
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
# ASYNC_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Azure Managed Identity (AAD Mode - Azure Deployment)
# These are automatically set by Azure Container Apps when deployed
AZURE_CLIENT_ID=

# Telemetry exporter switch
# Local default: false
# Azure deployment default: true (set via environment configuration)
ENABLE_TELEMETRY=false

# Application Insights (optional)
# Set this to enable OpenTelemetry telemetry export
# Automatically set by Azure Container Apps when deployed
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
