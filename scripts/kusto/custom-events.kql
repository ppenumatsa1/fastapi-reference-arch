let windowStart = ago(60m);
customEvents
| where timestamp >= windowStart
| where name startswith "user."
| project
    timestamp,
    operation_Id,
    operation_Name,
    name,
    user_action = tostring(customDimensions["user.action"]),
    user_id = tostring(customDimensions["user.id"])
| order by timestamp desc
| take 400
