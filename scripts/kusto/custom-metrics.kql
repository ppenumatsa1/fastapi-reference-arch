let windowStart = ago(60m);
customMetrics
| where timestamp >= windowStart
| where name startswith "user."
| project
    timestamp,
    operation_Id,
    operation_Name,
    name,
    value,
    user_action = tostring(customDimensions["user.action"]),
    user_outcome = tostring(customDimensions["user.outcome"])
| order by timestamp desc
| take 400
