let windowStart = ago(30m);
traces
| where timestamp >= windowStart
| project
    timestamp,
    operation_Id,
    operation_Name,
    severityLevel,
    message,
    path = tostring(customDimensions.path),
    code_function = tostring(customDimensions["code.function"]),
    code_filepath = tostring(customDimensions["code.filepath"]),
    code_lineno = tostring(customDimensions["code.lineno"])
| order by timestamp desc
| take 400
